{
  "family": "vibr-logging-test",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::474891440772:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "log-router",
      "image": "public.ecr.aws/aws-observability/aws-for-fluent-bit:stable",
      "essential": true,
      "firelensConfiguration": {
        "type": "fluentbit"
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/test-server-firelens",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "firelens"
        }
      }
    },
    {
      "name": "vibr-logging-test",
      "image": "474891440772.dkr.ecr.ap-northeast-2.amazonaws.com/vibr-logging-test:latest",
      "essential": true,
      "logConfiguration": {
        "logDriver": "awsfirelens",
        "options": {
          "Name": "loki",
          "host": "3.34.57.22",
          "port": "3100",
          "labels": "job=ecs-test,env=test",
          "remove_keys": "container_id,ecs_task_arn",
          "label_keys": "$container_name,$ecs_task_definition",
          "line_format": "json"
        }
      }
    }
  ]
}
